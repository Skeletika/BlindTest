{% extends 'base.html.twig' %}

{% block title %}ADMINISTRATOR{% endblock %}

{% block body %}

<h1>Mes Questions</h1>

<ul>
    <table class="table">
        <thead>
            <tr>
                <th scope='col'>Id</th>
                <th scope="col">Type</th>
                <th scope="col">Question</th>
                <th scope="col">Catégorie</th>
                <th scope="col">Indices</th>
                <th scope="col">Fichier PATH</th>
                <th scope="col">Réponses possibles</th>
                <th scope="col">ACTION</th>
            </tr>
        </thead>
        <tbody>
        {% for question in questions %}
        <tr>
            <td>{{ question.id }}</td>
            <td>{{ question.type }}</td>
            <td>{{ question.question }}</td>
            <td>{{ question.categorie.name }}</td>
            <td>{{ question.clue.clue }}</td>
            <td>{{ question.clue.path }}</td>
            <td>
                <p>
                    {% for answer in question.answer.answer %}
                    {{ answer }},
                    {% endfor %}
                </p>
            </td>
            <td>
                <a href="{{ path('app_admin_question', {id: question.id}) }}">Voir</a>
            </td>
        </tr>
        {% endfor %}
        </tbody>
    </table>

    {% endblock %}